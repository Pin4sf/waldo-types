{
  "name": "@pin4sf/waldo-types",
  "version": "0.2.0",
  "description": "Shared TypeScript contracts for Waldo — cross-repo type seam for waldo-backend and waldo-app",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^24.12.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pin4sf/waldo-types.git"
  }
}
